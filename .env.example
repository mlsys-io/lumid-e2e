# Copy this file to .env.local and fill in the secrets. Never commit .env.local.

# ---- Target ----
# Where tests run against. Default: prod. For offline dev, point at a
# local lumid-identity + lumid_landing_readdy stack.
BASE_URL=https://lum.id

# ---- Gmail mailbox (for OTP + reset-link polling) ----
# Dedicated test account. Uses IMAP + a Google "app password" (not your
# real password). Subaddress tagging (lumid-e2e+<tag>@lum.id) keeps
# concurrent runs isolated.
E2E_GMAIL_USER=lumid-e2e@lum.id
E2E_GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
E2E_GMAIL_HOST=imap.gmail.com
E2E_GMAIL_PORT=993

# ---- Admin persona ----
# Dedicated seed admin. Tests will change the password during the
# change-password spec (06) and reset it at the end of the spec to
# whatever is in E2E_ADMIN_PASSWORD. Create once via /register and
# promote to role=admin directly in the lumid-identity DB.
E2E_ADMIN_EMAIL=admin@lum.id
E2E_ADMIN_PASSWORD=<known-initial-password>

# ---- Invitation code ----
# Required by the /auth/register form. The signup spec pre-fills it
# via ?invite=<code>. Use any admin-issued code (mint one at
# /account/admin/invitations if you need a fresh one).
E2E_INVITATION_CODE=<any-valid-code>

# ---- CLI install lifecycle (TC14) ----
# Set to 1 in CI nightly to enable docker-based install.sh test.
CI_E2E_DOCKER=0
